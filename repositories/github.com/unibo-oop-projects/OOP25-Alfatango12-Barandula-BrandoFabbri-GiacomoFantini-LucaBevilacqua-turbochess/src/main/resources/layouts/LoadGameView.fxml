            <VBox fx:id="savesContainer" alignment="TOP_CENTER" spacing="10.0" style="-fx-background-color: transparent;">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </content>
         <VBox.margin>
            <Insets left="50.0" right="50.0" />
         </VBox.margin>
      </ScrollPane>
      <Button mnemonicParsing="false" onAction="#onBack" styleClass="button" text="Back" />
   </children>
</VBox>
