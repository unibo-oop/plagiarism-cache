      								<Font size="20.0" />
      							</font>
      						</RadioButton>
      				<RadioButton mnemonicParsing="false" text="NORMAL" textFill="#49618c" toggleGroup="$difficulty" GridPane.columnIndex="1" GridPane.rowIndex="1">
