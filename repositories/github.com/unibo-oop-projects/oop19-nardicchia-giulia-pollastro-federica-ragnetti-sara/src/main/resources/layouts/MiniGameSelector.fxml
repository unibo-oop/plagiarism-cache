               <GridPane.margin>
                  <Insets bottom="30.0" left="40.0" right="40.0" top="40.0" />
               </GridPane.margin>
				</Button>
				<ComboBox fx:id="gameComboBox" maxHeight="40.0" maxWidth="340.0" onMouseClicked="#initializeCombo" visibleRowCount="5" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1">
					<GridPane.margin>
						<Insets bottom="10.0" top="10.0" />
					</GridPane.margin>
				</ComboBox>
            <Label fx:id="label" alignment="CENTER" contentDisplay="CENTER" text="Select minigame" textFill="#49618c" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.valignment="BOTTOM">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Label fx:id="errorLbl" textFill="#dd0000" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="3" GridPane.valignment="CENTER">
							<font>
								<Font size="15.0" />
							</font>
						</Label>
            <GridPane fx:id="gridToggle" prefHeight="121.0" prefWidth="240.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" />
                  <ColumnConstraints maxWidth="1.7976931348623157E308" />
                <ColumnConstraints hgrow="SOMETIMES" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints vgrow="SOMETIMES" />
                <RowConstraints vgrow="SOMETIMES" />
                <RowConstraints vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
      						<RadioButton mnemonicParsing="false" text="HARD" textFill="#49618c" GridPane.columnIndex="1" GridPane.rowIndex="2">
