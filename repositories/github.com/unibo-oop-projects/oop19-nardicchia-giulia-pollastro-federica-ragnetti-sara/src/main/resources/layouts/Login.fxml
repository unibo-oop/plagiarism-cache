<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.paint.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.controllers.LoginFxImpl">
	<children>
		<GridPane fx:id="grid" GridPane.halignment="CENTER" GridPane.hgrow="ALWAYS" GridPane.rowIndex="2" GridPane.vgrow="ALWAYS" VBox.vgrow="ALWAYS">
			<columnConstraints>
				<ColumnConstraints hgrow="SOMETIMES" />
				<ColumnConstraints />
				<ColumnConstraints hgrow="SOMETIMES" />
			</columnConstraints>
			<rowConstraints>
				<RowConstraints vgrow="SOMETIMES" />
				<RowConstraints vgrow="SOMETIMES" />
				<RowConstraints vgrow="SOMETIMES" />
				<RowConstraints vgrow="SOMETIMES" />
				<RowConstraints vgrow="SOMETIMES" />
			</rowConstraints>

			<children>
				<Label contentDisplay="TEXT_ONLY" text="Brain Trainer" textFill="#49618c" textOverrun="CENTER_ELLIPSIS" GridPane.columnIndex="1" GridPane.halignment="CENTER">
					<font>
						<Font size="35.0" />
					</font>
				</Label>
				<ImageView fx:id="logo" fitHeight="255.0" fitWidth="277.0" nodeOrientation="INHERIT" pickOnBounds="true" preserveRatio="true" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1">
					<image>
						<Image url="@../images/brain_training.png" />
					</image>
					<GridPane.margin>
						<Insets bottom="15.0" />
					</GridPane.margin>
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
				</ImageView>
            <GridPane fx:id="gridBtn" GridPane.columnIndex="1" GridPane.rowIndex="4">
              <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" />
                <ColumnConstraints hgrow="SOMETIMES" />
                <ColumnConstraints hgrow="SOMETIMES" />
                  <ColumnConstraints hgrow="SOMETIMES" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="-Infinity" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
      						<Button fx:id="signUpBtn" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onMouseClicked="#signUpPlayer" text="Sign Up" textFill="#49618c" GridPane.columnIndex="1">
      							<font>
      								<Font size="18.0" />
      							</font>
      							<GridPane.margin>
      								<Insets bottom="20.0" right="10.0" />
      							</GridPane.margin>
      						</Button>
      						<Button fx:id="loginBtn" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onMouseClicked="#loginPlayer" text="Login" textFill="#49618c" GridPane.columnIndex="2">
      							<font>
      								<Font size="18.0" />
      							</font>
      							<GridPane.margin>
      								<Insets bottom="20.0" left="10.0" />
      							</GridPane.margin>
      						</Button>
               </children>
            </GridPane>
				<GridPane fx:id="gridFields" GridPane.columnIndex="1" GridPane.rowIndex="2">
					<columnConstraints>
						<ColumnConstraints hgrow="ALWAYS" />
						<ColumnConstraints hgrow="ALWAYS" />
					</columnConstraints>
					<rowConstraints>
						<RowConstraints vgrow="SOMETIMES" />
						<RowConstraints vgrow="SOMETIMES" />
					</rowConstraints>
					<children>
						<Label nodeOrientation="LEFT_TO_RIGHT" text="Username" textFill="#49618c" GridPane.halignment="RIGHT" GridPane.hgrow="ALWAYS" GridPane.valignment="CENTER">
							<font>
								<Font size="18.0" />
							</font>
							<GridPane.margin>
								<Insets bottom="10.0" right="20.0" />
							</GridPane.margin>
						</Label>
						<PasswordField fx:id="txtPassword" maxHeight="40.0" maxWidth="300.0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1" GridPane.valignment="CENTER" />
						<Label text="Password" textFill="#49618c" GridPane.halignment="RIGHT" GridPane.hgrow="ALWAYS" GridPane.rowIndex="1" GridPane.valignment="CENTER">
							<font>
								<Font size="18.0" />
							</font>
							<GridPane.margin>
								<Insets right="20.0" />
							</GridPane.margin>
						</Label>
						<TextField fx:id="txtPlayer" maxHeight="40.0" maxWidth="300.0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" GridPane.valignment="CENTER">
                     <GridPane.margin>
                        <Insets bottom="10.0" />
                     </GridPane.margin></TextField>
					</children>
				</GridPane>
            <GridPane fx:id="gridLbl" GridPane.columnIndex="1" GridPane.rowIndex="3">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
      				<Label fx:id="errorLbl" contentDisplay="CENTER" textFill="#dd0000" GridPane.halignment="CENTER">
      					<font>
      						<Font size="15.0" />
      					</font>
      					<GridPane.margin>
      						<Insets bottom="10.0" top="10.0" />
      					</GridPane.margin>
      				</Label>
               </children>
            </GridPane>

			</children>
		</GridPane>
	</children>
</VBox>
