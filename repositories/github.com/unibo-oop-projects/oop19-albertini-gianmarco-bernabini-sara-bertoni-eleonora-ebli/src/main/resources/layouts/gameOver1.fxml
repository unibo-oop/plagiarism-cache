                        <Font size="24.0" />
                     </font>
                  </Label>
                  <TextField fx:id="textText" layoutX="251.0" layoutY="120.0">
                     <tooltip>
                        <Tooltip fx:id="infoName" text="Max 10 char. Do not start with space. Press enter to save" />
                     </tooltip>
                  </TextField>
                  <Button fx:id="saveBtn" layoutX="386.0" layoutY="120.0" mnemonicParsing="false" onMouseClicked="#saveBtnOnClickHandler" text="Save">
                     <effect>
                        <DropShadow color="#da1e92" />
                     </effect>
                  </Button>
