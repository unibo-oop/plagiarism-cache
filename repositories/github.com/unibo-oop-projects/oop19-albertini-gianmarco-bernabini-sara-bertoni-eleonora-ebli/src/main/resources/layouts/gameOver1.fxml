                              <DropShadow color="#da1e92" />
                           </effect>
                        </Button>
                        <Button fx:id="menuBtn" mnemonicParsing="false" onMouseClicked="#menuBtnOnClickHandler" prefHeight="51.0" prefWidth="154.0" text="Menu">
