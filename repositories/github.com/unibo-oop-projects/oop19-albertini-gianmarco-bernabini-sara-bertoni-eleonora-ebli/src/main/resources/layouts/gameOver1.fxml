                              <DropShadow color="#da1e92" />
                           </effect>
                        </Button>
                     </children>
                  </VBox>
                  <Label fx:id="nameLbl" layoutX="183.0" layoutY="113.0" prefHeight="34.0" prefWidth="77.0" text="Name:" textFill="#da1e92">
