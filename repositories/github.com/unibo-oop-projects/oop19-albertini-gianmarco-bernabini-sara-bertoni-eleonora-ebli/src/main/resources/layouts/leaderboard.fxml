<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.effect.*?>
<?import javafx.scene.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.gui.leaderboard.GUILeaderboardControllerImpl">
   <children>
      <ImageView fx:id="img" fitHeight="720.0" fitWidth="1280.0" pickOnBounds="true" preserveRatio="false">
         <image>
            <Image url="@../images/leaderboardBackground.jpg" />
         </image>
      </ImageView>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <GridPane>
               <columnConstraints>
                  <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                  <ColumnConstraints hgrow="NEVER" minWidth="10.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="125.0" vgrow="ALWAYS" />
               </rowConstraints>
               <children>
                  <Label focusTraversable="false" text="LEADERBOARD" textFill="#da1e92" GridPane.columnIndex="1" GridPane.halignment="CENTER">
                     <font>
                        <Font size="74.0" />
                     </font>
                     <effect>
                        <Glow />
                     </effect>
                  </Label>
                  <Button focusTraversable="false" onMouseClicked="#backBtnOnClickHandler" text="Back to menu" BorderPane.alignment="CENTER_LEFT">
                     <GridPane.margin>
                        <Insets left="30.0" />
                     </GridPane.margin>
                     <effect>
                        <DropShadow color="#da1e92" />
                     </effect>
                  </Button>
                  <Button fx:id="infoBtn" focusTraversable="false" mnemonicParsing="false" onMouseClicked="#infoBtnOnClickHandler" text="Info" GridPane.columnIndex="2" GridPane.halignment="RIGHT">
                     <GridPane.margin>
                        <Insets right="30.0" />
                     </GridPane.margin>
                     <tooltip>
                        <Tooltip fx:id="tooltip" anchorLocation="CONTENT_TOP_RIGHT" anchorX="0.0" anchorY="0.0" text="Click me if you wanna get a higher score ;)" wrapText="true" x="0.0" y="0.0" />
                     </tooltip>
                     <effect>
                        <DropShadow color="#da1e92" />
                     </effect>
                  </Button>
               </children>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <BorderPane.margin>
                  <Insets />
               </BorderPane.margin>
            </GridPane>
         </top>
         <center>
            <StackPane>
               <children>
                  <ScrollPane fx:id="leaderboardPane" blendMode="MULTIPLY" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" pannable="true" prefViewportHeight="657.0" prefViewportWidth="1252.0">
                     <content>
                        <TableView fx:id="leaderboardTable" blendMode="MULTIPLY" focusTraversable="false" BorderPane.alignment="CENTER">
                          <columns>
                            <TableColumn fx:id="positionClmn" editable="false" prefWidth="75.0" sortable="false" style="-fx-alignment: CENTER;" text="Position" />
                              <TableColumn fx:id="nameClmn" editable="false" prefWidth="75.0" sortable="false" style="-fx-alignment: CENTER;" text="Name" />
                            <TableColumn fx:id="timeClmn" editable="false" prefWidth="75.0" sortable="false" style="-fx-alignment: CENTER;" text="Time" />
                              <TableColumn fx:id="scoreClmn" editable="false" prefWidth="75.0" sortable="false" style="-fx-alignment: CENTER;" text="Score" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </content>
                  </ScrollPane>
                  <VBox fx:id="infoScoreDialog" alignment="CENTER" fillWidth="false" spacing="25.0" visible="false" StackPane.alignment="CENTER">
                     <children>
                        <Label focusTraversable="false" text="Hi, wanna get a higher score?" textFill="#5f1ed9">
                           <font>
                              <Font size="48.0" />
                           </font>
                        </Label>
                        <TextArea blendMode="MULTIPLY" centerShape="false" editable="false" focusTraversable="false" text="Every letter that you enter correctly is worth two points, so every word completed values its number of letters multiplied for 2 and for the current combo value, but every second your score will decrease by one point, so you better be fast!&#10;Oh, sorry, i forgot to tell you! Every word you entered correctly increases the current combo value. This means you gotta be careful too, cuz if you type the wrong letter, your combo will reset :(&#10;" wrapText="true" VBox.vgrow="NEVER">
                           <effect>
                              <Blend mode="MULTIPLY" />
                           </effect>
                           <font>
                              <Font size="26.0" />
                           </font>
                        </TextArea>
                     </children>
                  </VBox>
               </children>
            </StackPane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
