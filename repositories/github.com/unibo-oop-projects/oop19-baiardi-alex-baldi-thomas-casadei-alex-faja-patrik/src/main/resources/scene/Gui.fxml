                                    </FlowPane>
                                    <FlowPane fx:id="enviromentPane" columnHalignment="CENTER" layoutX="292.0" layoutY="1.0" prefHeight="361.0" prefWidth="301.0" AnchorPane.bottomAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
