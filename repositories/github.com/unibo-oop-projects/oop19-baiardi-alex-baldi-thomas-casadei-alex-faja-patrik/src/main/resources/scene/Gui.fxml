                  <TabPane fx:id="tabPanel" prefHeight="389.3333333333333" prefWidth="605.3333333333334" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <tabs>
                      <Tab fx:id="tabSettings" closable="false" text="Settings">
