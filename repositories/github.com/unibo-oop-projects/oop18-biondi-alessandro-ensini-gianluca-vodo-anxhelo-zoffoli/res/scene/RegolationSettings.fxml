<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/8.0.171"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="view.RegolationSettingsController">
	<children>
		<HBox alignment="CENTER" spacing="10.0">
			<children>
				<Label fx:id="labelValueOfRegolation" />
			</children>
		</HBox>
		<HBox alignment="CENTER" spacing="10.0">
			<children>
				<Button fx:id="buttonDecrement" onAction="#decrement" />
				<Slider fx:id="sliderRegolation"
					onKeyReleased="#setRegolation" onMouseReleased="#setRegolation" />
				<Button fx:id="buttonIncrement" onAction="#increment" />
			</children>
			<padding>
				<Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
			</padding>
		</HBox>
		<HBox alignment="CENTER" spacing="10.0">
			<children>
				<Button fx:id="buttonApply" contentDisplay="CENTER"
					onAction="#apply" />
				<Button fx:id="buttonCancel" contentDisplay="CENTER"
					onAction="#cancel" />
			</children>
			<VBox.margin>
				<Insets />
			</VBox.margin>
			<padding>
				<Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
			</padding>
		</HBox>

	</children>
</VBox>
