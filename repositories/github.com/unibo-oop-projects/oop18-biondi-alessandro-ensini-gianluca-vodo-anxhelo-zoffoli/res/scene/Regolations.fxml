<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" minWidth="-Infinity" prefWidth="300.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.RegolationsController">
	<children>
		<Label fx:id="labelRegolations" alignment="CENTER" contentDisplay="CENTER" textAlignment="CENTER">
			<VBox.margin>
				<Insets />
			</VBox.margin>
			<padding>
				<Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
			</padding>
			<font>
				<Font size="20.0" />
			</font>
		</Label>
		<AnchorPane>
			<children>
				<Accordion AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
					<panes>
						<TitledPane fx:id="titledPaneBrightness" alignment="BOTTOM_LEFT" animated="false" expanded="false" graphicTextGap="10.0" onMouseClicked="#selectBrightness">
							<graphic>
								<ImageView fitHeight="21.0" fitWidth="21.0" pickOnBounds="true" preserveRatio="true">
									<Image url="/icons/regolations_brightness.png" />
								</ImageView>
							</graphic>
							<content>
							</content>
						</TitledPane>
						<TitledPane fx:id="titledPaneContrast" animated="false" expanded="false" graphicTextGap="10.0" onMouseClicked="#selectContrast">
							<graphic>
								<ImageView fitHeight="21.0" fitWidth="21.0" pickOnBounds="true" preserveRatio="true">
									<Image url="/icons/regolations_contrast.png" />
								</ImageView>
							</graphic>
							<content>
							</content>
						</TitledPane>
						<TitledPane fx:id="titledPaneSaturation" animated="false" expanded="false" graphicTextGap="10.0" onMouseClicked="#selectSaturation">
							<graphic>
								<ImageView fitHeight="21.0" fitWidth="21.0" pickOnBounds="true" preserveRatio="true">
									<Image url="/icons/regolations_saturation.png" />
								</ImageView>
							</graphic>
							<content>
							</content>
						</TitledPane>
						<TitledPane fx:id="titledPaneTemperature" animated="false" expanded="false" graphicTextGap="10.0" onMouseClicked="#selectTemperature">
							<graphic>
								<ImageView fitHeight="21.0" fitWidth="21.0" pickOnBounds="true" preserveRatio="true">
									<Image url="/icons/regolations_temperature.png" />
								</ImageView>
							</graphic>
							<content>
							</content>
						</TitledPane>
						<TitledPane fx:id="titledPaneExposure" animated="false" expanded="false" graphicTextGap="10.0" onMouseClicked="#selectExposure">
							<graphic>
								<ImageView fitHeight="21.0" fitWidth="21.0" pickOnBounds="true" preserveRatio="true">
									<Image url="/icons/regolations_exposure.png" />
								</ImageView>
							</graphic>
							<content>
							</content>
						</TitledPane>
					</panes>
				</Accordion>
			</children>
			<padding>
				<Insets bottom="10.0" top="10.0" />
			</padding>
		</AnchorPane>
	</children>
   <padding>
      <Insets right="10.0" />
   </padding>
</VBox>
