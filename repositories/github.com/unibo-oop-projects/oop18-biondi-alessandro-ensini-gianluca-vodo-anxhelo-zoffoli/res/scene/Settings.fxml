<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>


<VBox maxHeight="-Infinity" maxWidth="-Infinity"
	minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0"
	prefWidth="300.0" xmlns="http://javafx.com/javafx/8.0.171"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="view.SettingsController">
	<children>
		<HBox alignment="BASELINE_CENTER" spacing="10.0">
			<children>
				<Label alignment="CENTER" text="%label.lang" />
				<ComboBox fx:id="cmbLang" prefWidth="150.0" />
			</children>
			<padding>
				<Insets bottom="20.0" left="19.0" right="20.0" top="20.0" />
			</padding>
		</HBox>
		<Separator prefWidth="200.0" />
		<HBox alignment="BASELINE_CENTER" layoutX="10.0" layoutY="10.0"
			spacing="10.0">
			<children>
				<Label text="%label.theme" />
				<ComboBox fx:id="cmbTheme" prefWidth="150.0" />
			</children>
			<padding>
				<Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
			</padding>
		</HBox>
		<Separator prefWidth="200.0" />
		<Region prefHeight="200.0" prefWidth="200.0"
			VBox.vgrow="ALWAYS" />
		<Separator prefWidth="200.0" />
		<HBox alignment="CENTER" spacing="10.0">
			<children>
				<Button fx:id="buttonApply" text="%button.apply"
					onAction="#applySettings" />
				<Button fx:id="buttonCancel" text="%button.cancel"
					onAction="#cancel" />
			</children>
			<padding>
				<Insets bottom="5.0" left="20.0" right="20.0" top="5.0" />
			</padding>
		</HBox>
	</children>
</VBox>
