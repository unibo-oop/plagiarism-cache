<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="800.0" styleClass="overlay,frame" stylesheets="org/gitgud/styles/style.css" xmlns="http://javafx.com/javafx/8.0.111" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.gitgud.application.about.AboutBoxFxmlController">
   <children>
      <VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" styleClass="about-box" StackPane.alignment="TOP_CENTER">
         <StackPane.margin>
            <Insets top="100.0" />
         </StackPane.margin>
         <children>
            <ImageView fx:id="image" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="org/gitgud/images/sample.png" />
               </image></ImageView>
            <HBox alignment="CENTER">
               <children>
                  <Label alignment="CENTER" contentDisplay="CENTER" text="%label.about.title">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                     <padding>
                        <Insets bottom="10.0" top="10.0" />
                     </padding>
                  </Label>
                  <Region prefWidth="15.0" />
                  <Label text="%label.about.version">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <VBox fx:id="infoVbox" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="%label.about.developers">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Label>
                  <Label text="%label.about.emiliano" />
                  <Label text="%label.about.stefano" />
                  <Label text="%label.about.luca" />
                  <Region prefHeight="31.0" prefWidth="600.0" />
                  <Label alignment="TOP_LEFT" text="%label.about.repository" />
               </children></VBox>
            <Region />
            <HBox alignment="BOTTOM_RIGHT" VBox.vgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#btnCloseOnAction" styleClass="btn-secondary" text="%button.about.close" />
               </children>
               <padding>
                  <Insets bottom="20.0" right="20.0" />
               </padding>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
