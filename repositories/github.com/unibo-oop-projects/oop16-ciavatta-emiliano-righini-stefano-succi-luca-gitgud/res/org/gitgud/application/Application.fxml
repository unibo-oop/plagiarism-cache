<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1200.0" styleClass="body"
	stylesheets="org/gitgud/styles/style.css" xmlns="http://javafx.com/javafx/8.0.111"
	xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.gitgud.application.ApplicationFxmlController">
	<children>
		<MenuBar styleClass="main-menu" VBox.vgrow="NEVER">
			<menus>
				<Menu mnemonicParsing="false" text="%menu.file">
					<items>
						<MenuItem fx:id="miOpen" mnemonicParsing="false"
							onAction="#openRepositoryBox" text="%menuitem.open" />
						<MenuItem fx:id="miClone" mnemonicParsing="false"
							onAction="#openRepositoryBox" text="%menuitem.clone" />
						<MenuItem fx:id="miInit" mnemonicParsing="false"
							onAction="#openRepositoryBox" text="%menuitem.init" />
						<SeparatorMenuItem mnemonicParsing="false" />
						<MenuItem mnemonicParsing="false" onAction="#miQuitOnAction"
							text="%menuitem.quit" />
					</items>
				</Menu>
				<Menu mnemonicParsing="false" text="%menu.help">
					<items>
						<MenuItem mnemonicParsing="false" onAction="#miAboutOnAction"
							text="%menuitem.about" />
					</items>
				</Menu>
			</menus>
		</MenuBar>
		<StackPane fx:id="mainContainer" alignment="TOP_RIGHT"
			prefHeight="150.0" prefWidth="200.0" styleClass="body-wrapper"
			VBox.vgrow="ALWAYS" />
		<HBox prefHeight="20.0" prefWidth="200.0" styleClass="statusbar-wrapper"
			fx:id="statusWrapper">
			<children>
				<ProgressBar fx:id="pbTaskProgress" maxHeight="1.7976931348623157E308"
					maxWidth="1.7976931348623157E308" progress="0.0" styleClass="progress-task"
					HBox.hgrow="ALWAYS" />
			</children>
		</HBox>
	</children>
</VBox>
