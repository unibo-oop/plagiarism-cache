<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="400.0" prefWidth="600.0" styleClass="overlay,frame" stylesheets="org/gitgud/styles/style.css" xmlns="http://javafx.com/javafx/8.0.111" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" styleClass="box,modal-box">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" styleClass="modal-header">
               <children>
                  <Label styleClass="modal-title" text="Title goes here" fx:id="title" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" styleClass="btn-close" text="Close" fx:id="closeButton" />
               </children>
            </HBox>
            <VBox styleClass="modal-nodes-container" VBox.vgrow="ALWAYS" fx:id="nodesContainer" />
            <HBox alignment="CENTER_RIGHT" prefHeight="100.0">
               <children>
                  <Button mnemonicParsing="false" text="Cancel Button" styleClass="btn-bigger" fx:id="cancelButton">
                     <HBox.margin>
                        <Insets right="15.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" text="Secondary Button" styleClass="btn-bigger,btn-secondary" fx:id="secondaryButton">
                     <HBox.margin>
                        <Insets right="15.0" />
                     </HBox.margin>
                  </Button>
                  <Button mnemonicParsing="false" text="Primary Button" styleClass="btn-bigger,btn-primary" fx:id="primaryButton">
                     <HBox.margin>
                        <Insets right="15.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
