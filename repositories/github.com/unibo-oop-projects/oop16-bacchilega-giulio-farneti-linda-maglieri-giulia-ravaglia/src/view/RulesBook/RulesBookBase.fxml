            <Button fx:id="previousPage" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#doButtonPrevious" prefHeight="75.0" prefWidth="92.0" style="-fx-background-color: transparent; -fx-border-radius: 50;" BorderPane.alignment="CENTER">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
