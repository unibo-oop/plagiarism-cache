<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="400.0" prefWidth="500.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/8" fx:controller="main.view.GoodbyeWelcomeMessageController">
   <children>
      <VBox alignment="CENTER" prefHeight="400.0" prefWidth="500.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="Goodbye," textFill="#ff0404">
               <font>
                  <Font name="Goudy Old Style" size="48.0" />
               </font>
            </Label>
            <Label fx:id="goodbyePokemon" layoutX="243.0" layoutY="200.0" text="Label" textFill="#ff0404">
               <font>
                  <Font name="Goudy Old Style" size="48.0" />
               </font>
            </Label>
            <Label layoutX="243.0" layoutY="210.0" text="Welcome," textFill="#1aff00">
               <font>
                  <Font name="Goudy Old Style" size="48.0" />
               </font>
               <VBox.margin>
                  <Insets top="25.0" />
               </VBox.margin>
            </Label>
            <Label fx:id="welcomePokemon" layoutX="243.0" layoutY="221.0" text="Label" textFill="#1aff00">
               <font>
                  <Font name="Goudy Old Style" size="48.0" />
               </font>
            </Label>
            <Button mnemonicParsing="false" onMouseClicked="#requestBackToGameMenu" text="Back To Main Menu">
               <font>
                  <Font name="Corbel Bold" size="15.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </children>
</AnchorPane>
