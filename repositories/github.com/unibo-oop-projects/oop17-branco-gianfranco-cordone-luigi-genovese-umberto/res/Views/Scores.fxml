<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unibo.arkanoid.view.controllers.ScoresController">
   <bottom>
      <Button mnemonicParsing="false" onMouseClicked="#backClicked" text="BACK" BorderPane.alignment="CENTER_RIGHT">
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
      </Button>
   </bottom>
   <top>
      <Label text="ARKANOID" textAlignment="CENTER" BorderPane.alignment="CENTER">
         <font>
            <Font size="50.0" />
         </font>
         <BorderPane.margin>
            <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
         </BorderPane.margin>
      </Label>
   </top>
   <center>
      <TableView fx:id="scoreTable" maxWidth="-Infinity" prefHeight="276.0" prefWidth="430.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="player" prefWidth="75.0" text="PLAYER" />
          <TableColumn fx:id="score" prefWidth="75.0" text="SCORE" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>
</BorderPane>
