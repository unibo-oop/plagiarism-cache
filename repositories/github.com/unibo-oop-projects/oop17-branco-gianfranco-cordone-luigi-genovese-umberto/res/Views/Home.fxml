<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unibo.arkanoid.view.controllers.HomeController">
   <center>
      <VBox alignment="CENTER" maxWidth="-Infinity" prefWidth="300.0" spacing="35.0" BorderPane.alignment="CENTER">
         <children>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onMouseClicked="#playClicked" text="PLAY" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onMouseClicked="#scoresClicked" text="SCORES" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onMouseClicked="#exitClicked" text="EXIT" />
         </children>
      </VBox>
   </center>
   <bottom>
      <Button fx:id="audioButton" mnemonicParsing="false" onMouseClicked="#audioButtonClicked" text="Audio OFF" BorderPane.alignment="CENTER_RIGHT">
         <BorderPane.margin>
            <Insets bottom="6.0" right="10.0" />
         </BorderPane.margin>
      </Button>
   </bottom>
   <top>
      <Label text="ARKANOID" textAlignment="CENTER" BorderPane.alignment="CENTER">
         <font>
            <Font size="50.0" />
         </font>
      </Label>
   </top>
</BorderPane>
