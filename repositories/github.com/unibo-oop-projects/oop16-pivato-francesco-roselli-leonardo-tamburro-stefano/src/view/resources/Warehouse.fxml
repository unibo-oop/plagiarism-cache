<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.controllers.WarehouseHandler">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="75.0" prefWidth="780.0" spacing="30.0" BorderPane.alignment="CENTER">
         <children>
            <Button id="backBtn" fx:id="backBtn" mnemonicParsing="false" onAction="#back" text="back">
               <HBox.margin>
                  <Insets left="10.0" />
               </HBox.margin>
            </Button>
            <Button fx:id="addProductBtn" mnemonicParsing="false" onAction="#addProduct" text="Add product" />
         </children>
         <BorderPane.margin>
            <Insets left="10.0" right="10.0" />
         </BorderPane.margin></HBox>
   </top>
   <center>
      <TableView fx:id="table" onMouseClicked="#copyRow" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
            <TableColumn fx:id="productIdCol" prefWidth="120.0" text="codice prodotto" />
            <TableColumn fx:id="productNameCol" prefWidth="120.0" text="articolo" />
          <TableColumn fx:id="categoryCol" prefWidth="120.0" text="categoria" />
          <TableColumn fx:id="quantityCol" prefWidth="120.0" text="giacenza" />
            <TableColumn fx:id="priceCol" prefWidth="120.0" text="prezzo unitario" />
            <TableColumn fx:id="descriptionCol" prefWidth="120.0" text="descrizione" />
        </columns>
      </TableView>
   </center>
</BorderPane>
