<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox fx:id="menuContainer" alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1200.0" snapToPixel="false" styleClass="menu-container" stylesheets="@../css/MainMenu.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.pokemonbt.controller.view_controller.MenuController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="440.0" prefWidth="1200.0" snapToPixel="false" spacing="10.0">
         <padding>
            <Insets top="100.0" />
         </padding>
         <children>
            <ImageView fitHeight="225.0" fitWidth="613.0" pickOnBounds="true" preserveRatio="true" styleClass="title-container">
               <image>
                  <Image url="@../img/title.png" />
               </image>
            </ImageView>
            <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="menu-subtitle" text="OOP Version" />
         </children>
      </VBox>
      <VBox alignment="TOP_CENTER" prefHeight="460.0" prefWidth="1200.0" snapToPixel="false" spacing="44.0">
         <padding>
            <Insets top="44.0" />
         </padding>
         <children>
            <Button mnemonicParsing="false" onAction="#onBattle" styleClass="battle-button">
               <graphic>
                  <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="battle-button-text" text="Battle" />
               </graphic>
            </Button>
            <Button fx:id="loadBtn" mnemonicParsing="false" onMouseClicked="#onLoading" snapToPixel="false" styleClass="menu-generic-button">
               <graphic>
                  <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="generic-button-text" text="Load Game" />
               </graphic>
            </Button>
            <Button mnemonicParsing="false" onAction="#onSettings" styleClass="menu-generic-button">
               <graphic>
                  <Text fill="WHITE" onMouseClicked="#onSettings" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="generic-button-text" text="Settings" />
               </graphic>
            </Button>
            <Button mnemonicParsing="false" onAction="#onExit" styleClass="menu-generic-button">
               <graphic>
                  <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="generic-button-text" text="Exit" />
               </graphic>
            </Button>
         </children>
      </VBox>
   </children>
</VBox>
