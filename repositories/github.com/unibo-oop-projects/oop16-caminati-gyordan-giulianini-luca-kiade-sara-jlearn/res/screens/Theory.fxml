<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import com.jfoenix.controls.JFXDrawer?>
<?import com.jfoenix.controls.JFXTabPane?>
<?import com.jfoenix.controls.JFXHamburger?>
<?import com.jfoenix.controls.JFXRadioButton?>
<?import com.lynden.gmapsfx.GoogleMapView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import jfxtras.scene.layout.HBox?>

<BorderPane fx:id="mainBorderPanel" cache="true" cacheHint="SPEED" minHeight="600.0" minWidth="500.0" snapToPixel="false" xmlns="http://javafx.com/javafx/8.0.111" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <BorderPane id="exercise-bar" fx:id="toolbarBorder" cache="true" cacheHint="SPEED" minHeight="40.0" BorderPane.alignment="CENTER">
         <left>
            <HBox id="exercise-menu-bar" alignment="CENTER" cache="true" cacheHint="SPEED" focusTraversable="true" BorderPane.alignment="CENTER">
               <children>
                  <JFXHamburger id="exercise-hamburger" fx:id="hamburgerMenu" cache="true" cacheHint="SPEED" onMouseClicked="#handleBackMenu" onMouseEntered="#handleBackMenu" onMouseExited="#handleBackMenu" />
                  <JFXButton id="exercise-menu-button" fx:id="menuButton" cache="true" cacheHint="SPEED" />
               </children>
            </HBox>
         </left>
         <right>
            <JFXRadioButton id="exercise-levels-button" fx:id="radioButtonDrawer" cache="true" cacheHint="SPEED" contentDisplay="CENTER" nodeOrientation="RIGHT_TO_LEFT" onAction="#showDrawerModules" text="Units" BorderPane.alignment="CENTER">
               <padding>
                  <Insets right="20.0" />
               </padding>
            </JFXRadioButton>
         </right>
      </BorderPane>
   </top>
   <bottom>
      <BorderPane id="exercise-bar" cache="true" cacheHint="SPEED" BorderPane.alignment="CENTER">
         <center>
            <HBox id="exercise-bar" alignment="CENTER_RIGHT" cache="true" cacheHint="SPEED" minHeight="48.0" nodeOrientation="LEFT_TO_RIGHT" />
         </center>
      </BorderPane>
   </bottom>
   <center>
      <JFXTabPane id="exercise-tabPane" fx:id="tabPane" nodeOrientation="LEFT_TO_RIGHT" onMouseClicked="#tabPaneClicked" rotateGraphic="true" tabClosingPolicy="UNAVAILABLE">
        <tabs>
            <Tab text="">
               <content>
                  <VBox id="exercise-title-level" alignment="CENTER" cache="true" cacheHint="SPEED">
                     <children>
                        <BorderPane fx:id="borderTheory" cache="true" cacheHint="SPEED" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
               </content>
            </Tab>
          <Tab text="">
               <content>
                  <BorderPane fx:id="borderMaps" cache="true" cacheHint="SPEED" prefHeight="200.0" prefWidth="200.0">
                     <center>
                        <GoogleMapView fx:id="googleMapView" cache="true" cacheHint="SPEED" BorderPane.alignment="CENTER" />
                     </center></BorderPane>
               </content>
            </Tab>
        </tabs>
      </JFXTabPane>
   </center>
   <right>
      <JFXDrawer fx:id="drawerLevels" cache="true" cacheHint="SPEED" direction="RIGHT" BorderPane.alignment="CENTER" />
   </right>
</BorderPane>
