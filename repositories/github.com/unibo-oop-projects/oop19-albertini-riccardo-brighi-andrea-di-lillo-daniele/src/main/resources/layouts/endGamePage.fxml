                              </font>
                           </Label>
                           <ImageView fx:id="imgLogin" fitHeight="40.0" fitWidth="84.0" onMouseClicked="#imgLogin_onClick" pickOnBounds="true" preserveRatio="true">
                              <image>
                                 <Image url="@../images/Login-button.png" />
                              </image>
                              <HBox.margin>
                                 <Insets left="20.0" />
                              </HBox.margin>
                           </ImageView>
                        </children>
                        <padding>
                           <Insets left="30.0" />
                        </padding>
                     </HBox>
                  </children></StackPane>
               <StackPane prefHeight="77.0" prefWidth="350.0" style="-fx-background-color: #173d50;" GridPane.rowIndex="1" GridPane.rowSpan="2">
                  <children>
                     <VBox alignment="TOP_CENTER" maxHeight="-Infinity" prefHeight="143.0" prefWidth="350.0">
                        <children>
                           <Label alignment="CENTER" style="-fx-font-weight: bold;" text="SCORE" textFill="#00c8ff">
                              <font>
                                 <Font size="23.0" />
                              </font>
                           </Label>
                           <Label style="-fx-font-family: SquareFont;" text="50" textFill="WHITE">
                              <font>
                                 <Font size="36.0" />
                              </font>
                           </Label>
                           <Label stylesheets="@../css/style.css" text="BEST SCORE" textFill="#00c8ff">
                              <font>
                                 <Font size="19.0" />
                              </font>
                           </Label>
                           <Label alignment="TOP_LEFT" style="-fx-font-family: SquareFont;" text="85" textFill="WHITE">
                              <font>
                                 <Font size="35.0" />
                              </font>
                           </Label>
                        </children>
                     </VBox>
                  </children>
               </StackPane>
               <StackPane prefHeight="121.0" prefWidth="350.0" GridPane.rowIndex="6">
                  <children>
                     <GridPane>
                        <columnConstraints>
                           <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                           <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                           <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        </columnConstraints>
                        <rowConstraints>
                           <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        </rowConstraints>
                        <children>
                           <ImageView fx:id="restartButtonnn" fitHeight="47.0" fitWidth="154.0" pickOnBounds="true" preserveRatio="true" GridPane.columnIndex="1">
                              <image>
                                 <Image url="@../images/play-again.png" />
                              </image>
                           </ImageView>
                           <ImageView fx:id="stats" fitHeight="48.0" fitWidth="48.0" onMouseClicked="#clickHandler" pickOnBounds="true" preserveRatio="true">
                              <image>
                                 <Image url="@../images/top-scores.png" />
                              </image>
                           </ImageView>
                           <ImageView fx:id="btnHome" fitHeight="48.0" fitWidth="48.0" onMouseClicked="#btnHome_onClick" pickOnBounds="true" preserveRatio="true" GridPane.columnIndex="2">
                              <image>
                                 <Image url="@../images/home.png" />
                              </image>
                           </ImageView>
                        </children>
                     </GridPane>
                  </children></StackPane>
               <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" style="-fx-background-color: #173d50;" GridPane.rowIndex="4">
                  <children>
                     <Label style="-fx-font-family: 'SquareFont';" text="NEW BALL" textFill="WHITE">
                        <font>
                           <Font size="30.0" />
                        </font>
                        <HBox.margin>
                           <Insets left="30.0" />
                        </HBox.margin>
                     </Label>
                     <ImageView fitHeight="42.0" fitWidth="106.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                           <Image url="@../images/getBall.png" />
                        </image>
                        <HBox.margin>
                           <Insets left="60.0" />
                        </HBox.margin>
                     </ImageView>
                  </children>
               </HBox>
            </children>
         </GridPane>
      </children>
   </AnchorPane>
</Pane>
