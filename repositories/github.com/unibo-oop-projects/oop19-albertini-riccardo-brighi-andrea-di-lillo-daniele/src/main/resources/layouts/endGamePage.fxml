<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<Pane fx:id="MainPageContent" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/10.0.2-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FinalPageController">
   <AnchorPane maxHeight="600.0" maxWidth="350.0" prefHeight="600.0" prefWidth="350.0" style="-fx-background-color: #000000;">
      <children>
         <GridPane prefHeight="600.0" prefWidth="350.0" vgap="10.0">
            <columnConstraints>
               <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
               <StackPane prefHeight="150.0" prefWidth="200.0" style="-fx-background-color: #173d50;" GridPane.rowIndex="3">
                  <children>
                     <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0">
                        <children>
                           <ImageView fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                              <image>
                                 <Image url="@../images/coin.png" />
                              </image>
                           </ImageView>
                           <Label fx:id="lblPunteggio" style="-fx-font-family: SquareFont;" text="56" textFill="WHITE">
                              <font>
                                 <Font size="30.0" />
                              </font>
                              <HBox.margin>
                                 <Insets left="10.0" />
                              </HBox.margin>
                           </Label>
                           <ImageView fitHeight="43.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                              <image>
                                 <Image url="@../images/ad-coin.png" />
                              </image>
                              <HBox.margin>
                                 <Insets left="120.0" />
                              </HBox.margin>
                           </ImageView>
                        </children>
                        <padding>
                           <Insets left="30.0" />
                        </padding>
                     </HBox>
                  </children></StackPane>
               <StackPane prefHeight="150.0" prefWidth="200.0" style="-fx-background-color: #173d50;" GridPane.rowIndex="5">
                  <children>
                     <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0">
                        <children>
                           <Label style="-fx-font-family: SquareFont;" text="INSERISCI UTENTE" textFill="WHITE">
