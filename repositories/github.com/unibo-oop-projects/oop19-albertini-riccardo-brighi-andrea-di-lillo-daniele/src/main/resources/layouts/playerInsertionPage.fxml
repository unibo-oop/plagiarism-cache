                  <Font size="20.0" />
               </font>
            </Label>
            <TextField fx:id="txtTextBox" maxWidth="200.0" prefHeight="4.0" prefWidth="350.0" styleClass="textfield_style">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </TextField>
            <HBox alignment="CENTER" prefHeight="102.0" prefWidth="350.0">
               <children>
                  <Button fx:id="btnGetBack" defaultButton="true" mnemonicParsing="false" onMouseClicked="#btnGetBack_onClick" prefHeight="41.0" prefWidth="90.0" style="-fx-font-family: &quot;SquareFont&quot;;" styleClass="button_style" text="Indietro">
                     <HBox.margin>
                        <Insets right="20.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="btnSelect" mnemonicParsing="false" onMouseClicked="#btnSelect_onClick" prefHeight="41.0" prefWidth="90.0" style="-fx-font-family: &quot;SquareFont&quot;;" styleClass="button_style" text="Seleziona">
                     <HBox.margin>
