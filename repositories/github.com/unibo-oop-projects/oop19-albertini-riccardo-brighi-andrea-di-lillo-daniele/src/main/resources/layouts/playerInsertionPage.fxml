                  </Button>
               </children>
               <VBox.margin>
                  <Insets top="40.0" />
               </VBox.margin>
            </HBox>
            <Label fx:id="lblControl" styleClass="scrollpane-text" stylesheets="@../css/style.css" text="Controllo" textFill="WHITE" />
            <ImageView fx:id="imgPlay" fitHeight="74.0" fitWidth="139.0" pickOnBounds="true" preserveRatio="true">
