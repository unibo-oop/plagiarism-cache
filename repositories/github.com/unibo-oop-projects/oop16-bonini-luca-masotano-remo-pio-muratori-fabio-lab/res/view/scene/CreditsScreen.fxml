<?import javafx.scene.layout.VBox?>

<FlowPane id="darkGlassPane" fx:id="creditsRoot" alignment="CENTER" xmlns="http://javafx.com/javafx/8.0.111" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.controller.CreditsSceneController">
	<children>
		<BorderPane id="windowFrame" fx:id="contents">
			<top>
				<Label id="windowHeader" text="Credits" BorderPane.alignment="CENTER">
					<BorderPane.margin>
						<Insets />
					</BorderPane.margin>
				</Label>
			</top>
			<bottom>
				<FlowPane id="windowFooter" alignment="CENTER" columnHalignment="CENTER" BorderPane.alignment="CENTER">
					<BorderPane.margin>
						<Insets />
					</BorderPane.margin>
					<children>
						<Button fx:id="backButton" alignment="CENTER" mnemonicParsing="false" onAction="#backButtonPressed" text="Back" />
					</children>
				</FlowPane>
			</bottom>
         <center>
            <VBox id="windowContent" alignment="CENTER" BorderPane.alignment="CENTER">
               <children>
                  <Label text="Develope by:" />
                  <GridPane alignment="CENTER">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" />
                      <ColumnConstraints halignment="CENTER" hgrow="SOMETIMES" />
                      <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <Label text="Controller" />
                        <Label text="Bonini Luca" GridPane.columnIndex="1">
                           <GridPane.margin>
                              <Insets />
                           </GridPane.margin>
                        </Label>
                        <Label text="KALEINARX " GridPane.columnIndex="2" />
                        <Label text="Model" GridPane.rowIndex="1" />
                        <Label text="View" GridPane.rowIndex="2" />
                        <Label text="Masotano Remo Pio" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Muratori Fabio" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label text="rielh" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <Label text="fmuratori" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                     </children>
                     <VBox.margin>
                        <Insets bottom="30.0" />
                     </VBox.margin>
                  </GridPane>
                  <Label text="Font used: Upheaval TT (BRK)" />
                  <Label text="Graphics:  Bonini Luca">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </Label>
               </children>
            </VBox>
         </center>
		</BorderPane>
	</children>
</FlowPane>
